GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=replace-me
GITLAB_WEBHOOK_SECRET=replace-me
CODEX_CMD=codex exec -m gpt-5.4 -c model_reasoning_effort=\"high\" -
CLAUDE_CMD=claude -p --output-format stream-json --model sonnet --effort high --permission-mode bypassPermissions
# Optional local commands that print JSON like:
# {"remaining_percent": 62.5, "reset_at": "2026-03-22T18:00:00Z"}
# These hooks run non-interactively, so do not point them directly at
# interactive slash commands like `codex /status` or `claude /usage`.
CODEX_QUOTA_CMD=
CLAUDE_QUOTA_CMD=
COUNCIL_SYNTHESIS_PROVIDER=codex
SQLITE_PATH=/data/nimble-reviewer.db
REPO_CACHE_DIR=/cache/repos
REVIEW_TRACE_DIR=/data/review-traces
REVIEW_TIMEOUT_SEC=600
MAX_CONCURRENT_REVIEWS=1
GITLAB_GIT_USERNAME=oauth2
# Internal port inside the container.
PORT=8080
# Host port published by docker compose.
HOST_PORT=8080
